{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/epistemic-honesty.sh\"", "timeout": 2 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cognitive-triage.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/user-signal-detector.sh\"", "timeout": 3 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact|resume",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/simplicity-enforcer.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/code-quality-standards.sh\"", "timeout": 3 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/concise-response-enforcer.sh\"", "timeout": 3 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/concise-plan-mode.sh\"", "timeout": 3 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-write-review-hook.sh\"", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/completion-gate.sh\"", "timeout": 10 }
        ]
      }
    ]
  }
}
